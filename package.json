{
  "name": "mobile-mechanic-marketplace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "node --test",
    "test:booking": "node --test src/server/booking-requests/booking-request.test.mjs src/server/booking-requests/repository.integration.test.mjs src/app/api/booking-requests/route.test.mjs",
    "test:rego": "TEST_DATABASE_URL=postgresql:///rego_test node --test",
    "db:migrate": "node scripts/migrate.mjs",
    "privacy:purge": "node scripts/purge-booking-requests.mjs",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:update": "playwright test --update-snapshots=all"
  },
  "dependencies": {
    "next": "^16.2.9",
    "pg": "8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17"
  }
}
