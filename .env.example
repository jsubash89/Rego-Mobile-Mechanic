# Required pooled PostgreSQL URL for the server and migrations. In serverless
# production use the provider's transaction/session-compatible pooled URL.
DATABASE_URL=postgresql:///rego_dev
# Required by integration tests; must be disposable and must not be a shared or
# development database. Tests isolate themselves further with unique schemas.
TEST_DATABASE_URL=postgresql:///rego_test
# Positive integer from 1 through 20 (serverless default: 5).
DATABASE_POOL_MAX=5
# Production-only distributed abuse control. Generate independently; minimum 32 bytes.
BOOKING_RATE_LIMIT_SECRET=
# Optional bounded quota overrides (defaults: 10 submissions per 60000ms).
BOOKING_RATE_LIMIT=10
BOOKING_RATE_WINDOW_MS=60000
# Daily Vercel retention route Bearer secret; minimum 32 bytes.
CRON_SECRET=
# Conservative pilot retention; configurable only from 30 through 90 days.
BOOKING_RETENTION_DAYS=90
# Server-only pilot operator credentials. Generate three independent values of
# at least 32 bytes. Never prefix these with NEXT_PUBLIC.
OPERATOR_SHARED_SECRET=
OPERATOR_SESSION_SECRET=
OPERATOR_RATE_LIMIT_SECRET=
# Exact trusted browser origin (scheme, host, and optional port; no trailing slash/path).
OPERATOR_CANONICAL_ORIGIN=https://example.com
# Outside Vercel production, the edge proxy must overwrite the selected header
# and add x-operator-proxy-secret. Browser-supplied forwarding headers are ignored.
# OPERATOR_TRUSTED_PROXY_IP_HEADER=x-real-client-ip
# OPERATOR_TRUSTED_PROXY_SECRET=
# Outside Vercel production, both values are required. The trusted proxy must
# overwrite this IP header and add x-booking-proxy-secret; never pass client values.
# BOOKING_TRUSTED_PROXY_IP_HEADER=x-real-client-ip
# BOOKING_TRUSTED_PROXY_SECRET=
