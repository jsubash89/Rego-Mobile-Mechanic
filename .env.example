# Required pooled PostgreSQL URL for the server and migrations. In serverless
# production use the provider's transaction/session-compatible pooled URL.
DATABASE_URL=postgresql:///rego_dev
# Required by integration tests; must be disposable and must not be a shared or
# development database. Tests isolate themselves further with unique schemas.
TEST_DATABASE_URL=postgresql:///rego_test
# Positive integer from 1 through 20 (serverless default: 5).
DATABASE_POOL_MAX=5
